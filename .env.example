# ===========================================
# AI Database Performance Optimizer
# Environment Variables Configuration
# ===========================================
# 
# This file contains environment variable overrides for the YAML configuration.
# Values in this file will override the corresponding values in config/config.yaml
#
# Usage: Copy this file to .env and update the values as needed

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# For demo, use PostgreSQL
DATABASE_TYPE=postgresql
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=dbms_demo
DATABASE_USERNAME=your_db_user
DATABASE_PASSWORD=your_secure_password
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600
DATABASE_ECHO=false

# Legacy names (for compatibility)
DB_TYPE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dbms_demo
DB_USER=your_db_user
DB_PASSWORD=your_secure_password

# ===========================================
# API CONFIGURATION
# ===========================================
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# ===========================================
# MONITORING CONFIGURATION
# ===========================================
MONITORING_INTERVAL=60
SLOW_QUERY_THRESHOLD=1000
METRICS_RETENTION_DAYS=30
ENABLE_SYSTEM_METRICS=true
ENABLE_DATABASE_METRICS=true
ENABLE_QUERY_LOGGING=true

# ===========================================
# MACHINE LEARNING CONFIGURATION
# ===========================================
ML_MODEL_UPDATE_INTERVAL=3600
ML_PREDICTION_HORIZON=24
ML_MIN_TRAINING_SAMPLES=50
ML_MIN_R2_SCORE=0.3
ML_MAX_MAPE_PERCENTAGE=50
ML_ENABLE_CYCLICAL_ENCODING=true
ML_ENABLE_INTERACTION_FEATURES=true
ML_ENABLE_STATISTICAL_FEATURES=true

# ===========================================
# DASHBOARD CONFIGURATION
# ===========================================
DASHBOARD_PORT=8501
DASHBOARD_REFRESH_INTERVAL=10

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
LOG_LEVEL=INFO
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"
LOG_FILE=logs/app.log
LOG_MAX_FILE_SIZE=10MB
LOG_BACKUP_COUNT=5
LOG_CONSOLE=true
LOG_FILE_ENABLED=true

# ===========================================
# SECURITY CONFIGURATION
# ===========================================
SECURITY_ENABLE_AUTH=false
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_EXPIRATION_HOURS=24
RATE_LIMIT_ENABLED=false
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=10
API_KEYS_ENABLED=false

# ===========================================
# PERFORMANCE CONFIGURATION
# ===========================================
ENABLE_CACHING=false
CACHE_TTL_SECONDS=300
CONNECTION_POOL_SIZE=20
MAX_CONCURRENT_REQUESTS=100
REQUEST_TIMEOUT=30
ENABLE_COMPRESSION=true
COMPRESSION_THRESHOLD=1024

# ===========================================
# CORS CONFIGURATION (comma-separated)
# ===========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8501,http://127.0.0.1:8501
CORS_ALLOW_CREDENTIALS=true

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================
# Set to true to enable debug mode and additional endpoints
DEBUG=false
ENABLE_DEBUG_ENDPOINTS=true
ENABLE_PROFILING=false
MOCK_EXTERNAL_SERVICES=false
TEST_DATA_GENERATION=false
HOT_RELOAD=true

# ===========================================
# PRODUCTION SETTINGS
# ===========================================
# Override production-specific settings here
ENABLE_MONITORING=true
ENABLE_HEALTH_CHECKS=true
GRACEFUL_SHUTDOWN_TIMEOUT=30
WORKER_PROCESSES=4
MAX_MEMORY_USAGE_MB=1024
