# Production Environment Configuration
# AI Database Performance Optimizer Pro - Version 2.0.0

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_TYPE=sqlite
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dbms_production.db
DB_USERNAME=
DB_PASSWORD=
USE_CONFIG_DB=false

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false
API_DEBUG=false

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# API Key Authentication (comma-separated or individual keys)
API_KEYS=your_production_api_key_here,another_api_key_here
# Or use individual keys:
# API_KEY_1=your_first_api_key
# API_KEY_2=your_second_api_key

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000
RATE_LIMIT_BURST=10

# Security Settings
DISABLE_AUTH=false
DISABLE_RATE_LIMIT=false

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================
# Background Data Collection
ENABLE_BACKGROUND_COLLECTION=true
COLLECTION_INTERVAL=10  # seconds

# Monitoring Intervals
MONITORING_INTERVAL=60
SLOW_QUERY_THRESHOLD=1.0
MODEL_UPDATE_INTERVAL=3600

# =============================================================================
# MACHINE LEARNING CONFIGURATION
# =============================================================================
PREDICTION_HORIZON=24
MIN_TRAINING_SAMPLES=100
ANOMALY_DETECTION_WINDOW=50
ANOMALY_CONTAMINATION=0.1

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
ENABLE_CONSOLE_LOGGING=true
ENABLE_FILE_LOGGING=true
LOG_FILE_PATH=/var/log/dbms_optimizer.log

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8501,https://yourdomain.com
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# =============================================================================
# DASHBOARD CONFIGURATION
# =============================================================================
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8501
DASHBOARD_API_KEY=your_dashboard_api_key

# =============================================================================
# REDIS CONFIGURATION (for rate limiting and caching)
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================
# Database Connection Pooling
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_CONNECT_TIMEOUT=10
DB_READ_TIMEOUT=30
DB_WRITE_TIMEOUT=30

# API Performance
API_TIMEOUT=30
REQUEST_TIMEOUT=10
MAX_RETRIES=3
RETRY_DELAY=1

# =============================================================================
# NOTIFICATION CONFIGURATION
# =============================================================================
# Email Notifications (for alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=true
ALERT_EMAIL_FROM=alerts@yourcompany.com
ALERT_EMAIL_TO=admin@yourcompany.com

# Webhook Notifications (for alerts)
WEBHOOK_URL=https://your-webhook-endpoint.com/alerts
WEBHOOK_SECRET=your_webhook_secret

# =============================================================================
# OBSERVABILITY CONFIGURATION
# =============================================================================
# OpenTelemetry
OTEL_SERVICE_NAME=dbms-optimizer-pro
OTEL_SERVICE_VERSION=2.0.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_HEADERS=api-key=your_otel_api_key

# Prometheus Metrics
PROMETHEUS_PORT=9090
ENABLE_METRICS=true

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================
ENVIRONMENT=production
DEBUG=false
TESTING=false

# =============================================================================
# ADVANCED CONFIGURATION
# =============================================================================
# Feature Flags
ENABLE_ADVANCED_ANALYTICS=true
ENABLE_QUERY_INSIGHTS=true
ENABLE_ANOMALY_DETECTION=true
ENABLE_ML_PREDICTIONS=true
ENABLE_BACKGROUND_SCHEDULER=true

# Data Retention
DATA_RETENTION_DAYS=30
METRICS_RETENTION_DAYS=7
ANOMALY_RETENTION_DAYS=14

# Backup Configuration
ENABLE_AUTO_BACKUP=false
BACKUP_INTERVAL=24  # hours
BACKUP_PATH=/var/backups/dbms_optimizer

# =============================================================================
# EXTERNAL INTEGRATIONS
# =============================================================================
# New Relic (optional)
NEW_RELIC_LICENSE_KEY=your_new_relic_key
NEW_RELIC_APP_NAME=DBMS-Optimizer-Pro

# DataDog (optional)
DATADOG_API_KEY=your_datadog_key
DATADOG_APP_KEY=your_datadog_app_key

# =============================================================================
# SECURITY HARDENING
# =============================================================================
# SSL/TLS Configuration
SSL_CERT_PATH=/path/to/ssl/cert.pem
SSL_KEY_PATH=/path/to/ssl/key.pem
FORCE_HTTPS=true

# Session Security
SESSION_SECRET=your_very_long_random_secret_key_here
SESSION_TIMEOUT=3600

# Content Security Policy
CSP_ENABLED=true
CSP_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================
TEST_DATABASE_URL=sqlite:///test_dbms.db
TEST_API_KEY=test_api_key_12345
TEST_REDIS_URL=redis://localhost:6379/1
